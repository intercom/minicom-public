#!/bin/bash

set -e  # Exit on any error

echo "Starting FastAPI minicom app..."

# Check if virtual environment exists
if [ ! -d "fastapi/venv" ]; then
    echo "Error: Virtual environment not found. Please run script/fastapi/setup first."
    exit 1
fi

# Activate virtual environment
source fastapi/venv/bin/activate

# Start FastAPI development server
echo "Starting FastAPI development server on port 3000..."
uvicorn main:app --app-dir fastapi --host 127.0.0.1 --port 3000
